# Memex — Environment Variables
# Copy to .env and fill in values before running

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: host port 5436 (Docker) — see docker-compose.yml
DATABASE_URL=postgresql://memex:memex@localhost:5436/memex

# ── Ollama (local AI — zero cost) ─────────────────────────────────────────────
# Uses native Ollama on port 11434 (no Docker — GPU works out of the box).
# Pull models once: ollama pull llama3.2 && ollama pull nomic-embed-text
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3002

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-random-32-char-string

# ── Optional: Anthropic Claude API ───────────────────────────────────────────
# USE_CLAUDE=true routes aiChat() through Claude instead of Ollama.
# Only wired to the manual "Enhance with Claude" button — NEVER called automatically.
# Leave USE_CLAUDE unset (or false) for fully local, zero-cost mode.
USE_CLAUDE=false
CLAUDE_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=
